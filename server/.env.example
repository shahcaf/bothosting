# Core
PORT=5000
NODE_ENV=development

# Discord OAuth2
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
DISCORD_REDIRECT_URI=http://localhost:5000/auth/discord/callback

# CockroachDB (PG compatible)
# Format: postgresql://[user]:[password]@[host]:[port]/[db]?sslmode=verify-full
DATABASE_URL=postgresql://root@localhost:26257/defaultdb?sslmode=disable

# JWT Secret
JWT_SECRET=super_secret_key_change_me

# Docker Socket (default for Linux/Windows usually)
DOCKER_SOCKET=/var/run/docker.sock
# On Windows, you might need npipe:////./pipe/docker_engine if using native docker

# Bot Host Path (where bot files are stored on host)
BOT_STORAGE_PATH=C:/Users/gwlnw/.gemini/antigravity/scratch/discord-bot-hosting/bots
